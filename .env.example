# PostgreSQL
POSTGRES_DB=rootdocs
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme

# Spring Datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/rootdocs
SPRING_DATASOURCE_USERNAME=changeme
SPRING_DATASOURCE_PASSWORD=changeme

# JWT
JWT_SECRET=changeme_to_a_secure_base64_string

# Default seed users
SEED_ADMIN_PASSWORD=changeme
SEED_LEITOR_PASSWORD=changeme